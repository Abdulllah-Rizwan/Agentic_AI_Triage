# ============================================================
# apps/dashboard/.env.local.example
# Copy this to apps/dashboard/.env.local and fill in your values
# ============================================================

# NextAuth — any random string
NEXTAUTH_SECRET=replace_this_with_a_long_random_string
NEXTAUTH_URL=http://localhost:3000

# API server URL
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
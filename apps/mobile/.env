# ============================================================
# apps/mobile/.env.example
# Copy this to apps/mobile/.env and fill in your values
# ============================================================

# Your API server URL
# For local dev: use your computer's LAN IP (not localhost!)
# Find it: ipconfig (Windows) or ifconfig (Mac/Linux) → look for 192.168.x.x
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.100:3001

# Google Gemini API key (same key as the backend)
EXPO_PUBLIC_GEMINI_API_KEY=AIzaSyAPUrTtacPvK1nw1iBfWcmQRpBHVtuQq9g

# Set to "development" to use Ollama instead of the bundled SLM model
# Set to "production" to use the bundled Llama 3.2 1B model
EXPO_PUBLIC_ENVIRONMENT=development

# Only needed when EXPO_PUBLIC_ENVIRONMENT=development
# Your computer's LAN IP running Ollama
EXPO_PUBLIC_OLLAMA_URL=http://192.168.1.100:11434
